# =============================================================================
# Devin FinOps Dashboard - Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# The .env file is loaded automatically by spring-dotenv at startup.
# DO NOT commit .env to version control.
# =============================================================================

# Enterprise service user token for enterprise-scoped API endpoints.
# Provision at: https://app.devin.ai → Enterprise Settings → Service Users
# Required permissions: ViewAccountMetrics, ManageBilling, ManageEnterpriseSettings
DEVIN_ENTERPRISE_SERVICE_USER_TOKEN=

# Organization service user token for organization-scoped API endpoints.
# Provision at: https://app.devin.ai → Organization Settings → Service Users
# Optional: if not set, org-scoped endpoints are skipped.
DEVIN_ORG_SERVICE_USER_TOKEN=

# (Optional) Organization ID. If set, the backend will use this single org
# instead of auto-discovering organizations via list_organizations.
# Leave blank or remove to enable automatic multi-org discovery.
DEVIN_ORG_ID=

# Dashboard polling interval in seconds (default: 5)
DASHBOARD_POLLING_INTERVAL_SECONDS=5

# Organization auto-discovery refresh interval in seconds (default: 60)
DASHBOARD_ORG_DISCOVERY_REFRESH_SECONDS=60
