# Enterprise service user token (required)
# Provision at: https://app.devin.ai → Enterprise Settings → Service Users
DEVIN_ENTERPRISE_SERVICE_TOKEN=your_enterprise_service_token_here

# Organization service user token (optional)
# Provision at: https://app.devin.ai → Organization Settings → Service Users
DEVIN_ORG_SERVICE_TOKEN=your_org_service_token_here

# Organization ID (optional - leave blank for multi-org auto-discovery)
DEVIN_ORG_ID=
